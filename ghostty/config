theme = "Monokai Pro Light"

window-decoration = none
font-family = "Berkeley Mono"
font-feature = "-calt"
font-size = 20
adjust-cell-height = 0%

window-vsync = false

cursor-text = #ffffff

background = FAFAFA
foreground = 575F66
cursor-color = 36A3D9

# Normal colors
palette = 0=#000000
palette = 1=#F07171
palette = 2=#86B300
palette = 3=#A37ACC
palette = 4=#36A3D9
palette = 5=#F07171
palette = 6=#4CBF99
palette = 7=#ABB0B6

# Bright colors
palette = 8=#828C99
palette = 9=#FF3333
palette = 10=#86B300
palette = 11=#F29718
palette = 12=#36A3D9
palette = 13=#F07171
palette = 14=#4CBF99
palette = 15=#FAFAFA

window-padding-x = 0
window-padding-y = 0
window-padding-color = extend-always
window-padding-balance = true
app-notifications = no-clipboard-copy
mouse-scroll-multiplier = 1.5
quit-after-last-window-closed = true
confirm-close-surface = false

keybind = clear
keybind = alt+y=copy_to_clipboard
keybind = alt+p=paste_from_clipboard
keybind = alt+shift+h=decrease_font_size:1
keybind = alt+shift+l=increase_font_size:1
keybind = alt+shift+j=write_scrollback_file:open
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down


shell-integration = fish
shell-integration-features = cursor,title,sudo

window-subtitle = working-directory


# claude config
keybind = shift+enter=text:\n

# vim: ft=config
